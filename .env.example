# ---------------------------------------------------------------
# Configuración del Bot de Polymarket
# Copia este archivo como .env y ajusta los valores
# NUNCA subas .env a git (ya está en .gitignore)
# ---------------------------------------------------------------

# ── Estrategia ──────────────────────────────────────────────────
# Rango de precios a filtrar
PRECIO_MIN=0.88
PRECIO_MAX=0.96

# Límite máximo a invertir por posición (en USDC)
LIMITE_POR_POSICION=2.50

# Intervalo entre ciclos de análisis (en minutos)
INTERVALO_MINUTOS=30

# ── Modo de operación ────────────────────────────────────────────
# "true"  → solo analiza y muestra el ranking, NO envía órdenes
# "false" → opera con dinero real (requiere credenciales abajo)
MODO_SIMULACION=true

# ── Credenciales de wallet (solo necesarias con MODO_SIMULACION=false) ──
# Tu clave privada en hex (sin el prefijo 0x)
# IMPORTANTE: guárdala de forma segura, nunca la compartas
WALLET_PRIVATE_KEY=

# Tu dirección pública de wallet (con 0x)
WALLET_ADDRESS=

# Tipo de firma:
#   0 = EOA estándar (MetaMask, Ledger, clave privada directa)
#   1 = Wallet de email/Magic Link (proxy wallet)
SIGNATURE_TYPE=0

# Red de Polygon (no cambiar salvo testnet)
CHAIN_ID=137

# ── Logging ──────────────────────────────────────────────────────
# Nombre del archivo CSV donde se guardan los registros
LOG_CSV=operaciones.csv
