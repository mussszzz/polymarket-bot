# ---------------------------------------------------------------
# Configuración del Bot de Polymarket
# Copia este archivo como .env y ajusta los valores
# ---------------------------------------------------------------

# Rango de precios a filtrar (estrategia bonos de alta probabilidad)
PRECIO_MIN=0.88
PRECIO_MAX=0.96

# Límite máximo a invertir por posición (en USD)
LIMITE_POR_POSICION=2.50

# Intervalo entre ciclos de análisis (en minutos)
INTERVALO_MINUTOS=30

# Modo simulación: "true" = solo analiza, no envía órdenes reales
# Cambia a "false" solo cuando quieras operar con dinero real
MODO_SIMULACION=true

# Nombre del archivo CSV donde se guardan los logs de operaciones
LOG_CSV=operaciones.csv
